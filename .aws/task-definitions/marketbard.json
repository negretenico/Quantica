{
  "family": "marketbard",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::{{ACCOUNT_ID}}:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "marketbard",
      "image": "ghcr.io/negretenico/quantica/marketbard:marketbard-latest",
      "essential": true,
      "secrets": [
        {
          "name": "RABBITMQ_URL",
          "valueFrom": "arn:aws:secretsmanager:{{AWS_REGION}}:{{ACCOUNT_ID}}:secret:prod/Quantica/EnvVariables:quantica/RABBITMQ_URL::"
        },
        {
          "name": "OPEN_AI_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:{{AWS_REGION}}:{{ACCOUNT_ID}}:secret:prod/Quantica/EnvVariables:quantica/OPEN_AI_TOKEN::"
        },
        {
          "name": "GH_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:{{AWS_REGION}}:{{ACCOUNT_ID}}:secret:prod/Quantica/EnvVariables:quantica/GH_TOKEN::"
        },
        {
          "name": "GITHUB_REPO",
          "valueFrom": "arn:aws:secretsmanager:{{AWS_REGION}}:{{ACCOUNT_ID}}:secret:prod/Quantica/EnvVariables:quantica/GITHUB_REPO::"
        }
      ],
      "environment": [
        { "name": "RABBITMQ_QUEUE", "value": "signal.bard" },
        { "name": "ANALYTICS_EXCHANGE", "value": "analytics" },
        { "name": "WINDOW_MINUTES", "value": "10" },
        { "name": "MAX_SUMMARY_BUFFER", "value": "50" },
        { "name": "WINDOW_SUMMARY_MAX_TOKENS", "value": "150" },
        { "name": "SYNTHESIS_MAX_TOKENS", "value": "800" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/marketbard",
          "awslogs-region": "{{AWS_REGION}}",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
