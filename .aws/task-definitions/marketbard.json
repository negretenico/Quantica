{
  "family": "marketbard",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::{{ACCOUNT_ID}}:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "marketbard",
      "image": "ghcr.io/negretenico/quantica/marketbard:marketbard-latest",
      "essential": true,
      "secrets": [
        {
          "name": "RABBITMQ_URL",
          "valueFrom": "arn:aws:secretsmanager:{{AWS_REGION}}:{{ACCOUNT_ID}}:secret:quantica/RABBITMQ_URL"
        },
        {
          "name": "OPEN_AI_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:{{AWS_REGION}}:{{ACCOUNT_ID}}:secret:quantica/OPEN_AI_TOKEN"
        },
        {
          "name": "GH_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:{{AWS_REGION}}:{{ACCOUNT_ID}}:secret:quantica/GH_TOKEN"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/marketbard",
          "awslogs-region": "{{AWS_REGION}}",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
