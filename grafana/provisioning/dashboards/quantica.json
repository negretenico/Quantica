{
  "title": "Quantica Pipeline",
  "uid": "quantica-pipeline",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "kafka_consumer_fetch_manager_records_lag{job=\"markettransformer\"}",
          "legendFormat": "{{topic}} / {{partition}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Kafka Records Consumed / sec",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "kafka_consumer_fetch_manager_records_consumed_rate{job=\"markettransformer\"}",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{job}} {{id}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Request Rate (actuator)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_server_requests_seconds_count[1m])",
          "legendFormat": "{{job}} {{uri}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Process Uptime",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_uptime_seconds",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "CPU Usage",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_cpu_usage",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
